            "border_width": "1",
            "shadow_width": "0",
            "text_horiz_alignment": "left"
        }
    },

    "#nav_subitem": {
        "colours": {
            "normal_bg": "#181825",
            "hovered_bg": "#2E86AB",
            "active_bg": "#145C8E",
            "normal_text": "#BAC2DE",
            "hovered_text": "#FFFFFF",
            "normal_border": "#181825",
            "hovered_border": "#2E86AB"
        },
        "misc": {
            "shape": "rounded_rectangle",
            "shape_corner_radius": "8",
            "border_width": "1",
            "shadow_width": "0",
            "text_horiz_alignment": "left"
        }
    }
